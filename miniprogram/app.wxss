/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f5f5;
  color: #333;
  font-size: 14px;
}

/* 通用样式 */
.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 按钮样式 */
button {
  border: none;
  outline: none;
}

button::after {
  border: none;
}

/* 输入框样式 */
input {
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  padding: 0 15rpx;
  font-size: 14px;
  height: 60rpx;
}

/* 通用卡片样式 */
.card {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 通用标题样式 */
.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

/* 通用列表样式 */
.list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

/* 通用项样式 */
.item {
  padding: 15rpx;
  background-color: white;
  border-radius: 5rpx;
  box-shadow: 0 2rpx 5rpx rgba(0, 0, 0, 0.05);
}

/* 通用图标样式 */
.icon {
  font-size: 24rpx;
  margin-right: 10rpx;
}

/* 通用分隔线 */
.divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 15rpx 0;
}

/* 通用加载样式 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}

/* 通用空状态样式 */
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 14px;
}

/* 通用错误提示样式 */
.error {
  color: #E60012;
  font-size: 12px;
  margin-top: 5rpx;
}

/* 通用成功提示样式 */
.success {
  color: #52c41a;
  font-size: 12px;
  margin-top: 5rpx;
}

/* 通用警告提示样式 */
.warning {
  color: #faad14;
  font-size: 12px;
  margin-top: 5rpx;
}

/* 通用信息提示样式 */
.info {
  color: #1890ff;
  font-size: 12px;
  margin-top: 5rpx;
}

/* 通用隐藏样式 */
.hidden {
  display: none;
}

/* 通用显示样式 */
.show {
  display: block;
}

/* 通用弹性布局 */
.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-center {
  align-items: center;
  justify-content: center;
}

.flex-between {
  justify-content: space-between;
  align-items: center;
}

.flex-around {
  justify-content: space-around;
  align-items: center;
}

/* 通用文本溢出样式 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 通用多行文本溢出样式 */
.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 通用动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.fade-in {
  animation: fadeIn 0.3s ease-in-out;
}

/* 通用阴影 */
.shadow {
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 通用圆角 */
.rounded {
  border-radius: 5rpx;
}

.rounded-lg {
  border-radius: 10rpx;
}

.rounded-full {
  border-radius: 50%;
}

/* 通用边距 */
.mt-1 {
  margin-top: 10rpx;
}

.mt-2 {
  margin-top: 20rpx;
}

.mt-3 {
  margin-top: 30rpx;
}

.mb-1 {
  margin-bottom: 10rpx;
}

.mb-2 {
  margin-bottom: 20rpx;
}

.mb-3 {
  margin-bottom: 30rpx;
}

.ml-1 {
  margin-left: 10rpx;
}

.ml-2 {
  margin-left: 20rpx;
}

.mr-1 {
  margin-right: 10rpx;
}

.mr-2 {
  margin-right: 20rpx;
}

/* 通用内边距 */
.p-1 {
  padding: 10rpx;
}

.p-2 {
  padding: 20rpx;
}

.p-3 {
  padding: 30rpx;
}

/* 通用颜色 */
.text-primary {
  color: #E60012;
}

.text-secondary {
  color: #666;
}

.text-muted {
  color: #999;
}

.text-success {
  color: #52c41a;
}

.text-warning {
  color: #faad14;
}

.text-danger {
  color: #E60012;
}

.text-info {
  color: #1890ff;
}

/* 通用背景色 */
.bg-primary {
  background-color: #E60012;
}

.bg-secondary {
  background-color: #f5f5f5;
}

.bg-white {
  background-color: white;
}

.bg-gray {
  background-color: #f0f0f0;
}

/* 通用边框 */
.border {
  border: 1rpx solid #ddd;
}

.border-top {
  border-top: 1rpx solid #ddd;
}

.border-bottom {
  border-bottom: 1rpx solid #ddd;
}

.border-left {
  border-left: 1rpx solid #ddd;
}

.border-right {
  border-right: 1rpx solid #ddd;
}

/* 通用字体大小 */
.text-xs {
  font-size: 12px;
}

.text-sm {
  font-size: 14px;
}

.text-base {
  font-size: 16px;
}

.text-lg {
  font-size: 18px;
}

.text-xl {
  font-size: 20px;
}

/* 通用字体粗细 */
.font-normal {
  font-weight: normal;
}

.font-medium {
  font-weight: 500;
}

.font-bold {
  font-weight: bold;
}

/* 通用文本对齐 */
.text-left {
  text-align: left;
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

/* 通用宽度 */
.w-full {
  width: 100%;
}

.w-1-2 {
  width: 50%;
}

.w-1-3 {
  width: 33.333%;
}

.w-1-4 {
  width: 25%;
}

/* 通用高度 */
.h-full {
  height: 100%;
}

.h-screen {
  height: 100vh;
}

/* 通用位置 */
.relative {
  position: relative;
}

.absolute {
  position: absolute;
}

.fixed {
  position: fixed;
}

/* 通用z-index */
.z-10 {
  z-index: 10;
}

.z-20 {
  z-index: 20;
}

.z-30 {
  z-index: 30;
}

.z-40 {
  z-index: 40;
}

.z-50 {
  z-index: 50;
}