/* 全局样式 - iOS Design System */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', 'PingFang SC', sans-serif;
  background-color: #F2F2F7;
  color: #000000;
  font-size: 14px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  -webkit-appearance: none;
}

/* iOS Design Tokens */
page {
  --ios-blue: #007AFF;
  --ios-green: #34C759;
  --ios-orange: #FF9500;
  --ios-red: #FF3B30;
  --ios-yellow: #FFCC00;
  --ios-gray: #8E8E93;
  --ios-gray2: #AEAEB2;
  --ios-gray3: #C7C7CC;
  --ios-gray4: #D1D1D6;
  --ios-gray5: #E5E5EA;
  --ios-gray6: #F2F2F7;
  
  --color-primary: #007AFF;
  --color-success: #34C759;
  --color-warning: #FF9500;
  --color-danger: #FF3B30;
  --color-info: #5AC8FA;
  
  --color-background: #F2F2F7;
  --color-surface: #FFFFFF;
  --color-surface-secondary: #F9F9FB;
  --color-text-primary: #000000;
  --color-text-secondary: #3C3C43;
  --color-text-tertiary: #3C3C4399;
  --color-border: #C6C6C8;
  --color-separator: #C6C6C8;
  
  --spacing-xs: 4rpx;
  --spacing-sm: 8rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;
  --spacing-2xl: 48rpx;
  
  --radius-xs: 4rpx;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 20rpx;
  --radius-full: 9999rpx;
  
  --shadow-xs: 0 1rpx 2rpx rgba(0,0,0,0.05);
  --shadow-sm: 0 2rpx 4rpx rgba(0,0,0,0.08);
  --shadow-md: 0 4rpx 8rpx rgba(0,0,0,0.1);
  --shadow-lg: 0 8rpx 16rpx rgba(0,0,0,0.12);
  
  --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
  --transition-normal: 300ms cubic-bezier(0.4, 0, 0.2, 1);
}

/* 通用样式 */
.container {
  padding: var(--spacing-md);
  min-height: 100vh;
  background: var(--color-background);
}

/* 按钮样式 - iOS Style */
button {
  border: none;
  outline: none;
  background: var(--color-primary);
  color: white;
  border-radius: var(--radius-md);
  padding: 22rpx 32rpx;
  font-size: 17rpx;
  font-weight: 500;
  min-height: 88rpx;
  transition: all var(--transition-fast);
}

button::after {
  border: none;
}

button:active {
  opacity: 0.8;
  transform: scale(0.98);
}

button[plain] {
  background: transparent;
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
}

button[disabled] {
  background: var(--ios-gray4);
  color: var(--ios-gray);
}

/* 输入框样式 - iOS Style */
input {
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: 17rpx;
  height: 88rpx;
  background: var(--color-surface);
  transition: all var(--transition-fast);
}

input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 6rpx rgba(0, 122, 255, 0.15);
}

input::placeholder {
  color: var(--color-text-tertiary);
}

/* 通用卡片样式 - iOS Style */
.card {
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-normal);
}

.card:active {
  transform: scale(0.99);
}

/* 通用标题样式 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
}

/* 通用列表样式 */
.list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

/* 通用项样式 */
.item {
  padding: var(--spacing-md);
  background-color: var(--color-surface);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-xs);
}

/* 通用图标样式 */
.icon {
  font-size: 48rpx;
  margin-right: var(--spacing-sm);
}

/* 通用分隔线 */
.divider {
  height: 2rpx;
  background-color: var(--color-separator);
  margin: var(--spacing-md) 0;
}

/* 通用加载样式 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: var(--spacing-xl) 0;
}

/* 通用空状态样式 */
.empty {
  text-align: center;
  padding: var(--spacing-2xl) 0;
  color: var(--color-text-tertiary);
  font-size: 15rpx;
}

/* 通用错误提示样式 */
.error {
  color: var(--color-danger);
  font-size: 24rpx;
  margin-top: var(--spacing-xs);
}

/* 通用成功提示样式 */
.success {
  color: var(--color-success);
  font-size: 24rpx;
  margin-top: var(--spacing-xs);
}

/* 通用警告提示样式 */
.warning {
  color: var(--color-warning);
  font-size: 24rpx;
  margin-top: var(--spacing-xs);
}

/* 通用信息提示样式 */
.info {
  color: var(--color-info);
  font-size: 24rpx;
  margin-top: var(--spacing-xs);
}

/* 通用动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.fade-in {
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes slideUp {
  from {
    transform: translateY(20rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.slide-up {
  animation: slideUp 0.3s ease-in-out;
}

/* 通用阴影 */
.shadow {
  box-shadow: var(--shadow-sm);
}

/* 通用圆角 */
.rounded {
  border-radius: var(--radius-sm);
}

.rounded-lg {
  border-radius: var(--radius-lg);
}

.rounded-full {
  border-radius: 50%;
}

/* 通用边距 - 使用Design Tokens */
.mt-1 { margin-top: var(--spacing-sm); }
.mt-2 { margin-top: var(--spacing-md); }
.mt-3 { margin-top: var(--spacing-lg); }
.mt-4 { margin-top: var(--spacing-xl); }

.mb-1 { margin-bottom: var(--spacing-sm); }
.mb-2 { margin-bottom: var(--spacing-md); }
.mb-3 { margin-bottom: var(--spacing-lg); }
.mb-4 { margin-bottom: var(--spacing-xl); }

.ml-1 { margin-left: var(--spacing-sm); }
.ml-2 { margin-left: var(--spacing-md); }
.ml-3 { margin-left: var(--spacing-lg); }

.mr-1 { margin-right: var(--spacing-sm); }
.mr-2 { margin-right: var(--spacing-md); }
.mr-3 { margin-right: var(--spacing-lg); }

/* 通用内边距 - 使用Design Tokens */
.p-1 { padding: var(--spacing-sm); }
.p-2 { padding: var(--spacing-md); }
.p-3 { padding: var(--spacing-lg); }
.p-4 { padding: var(--spacing-xl); }

/* 通用颜色 */
.text-primary { color: #E60012; }
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-tertiary); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }
.text-info { color: var(--color-info); }

/* 通用背景色 */
.bg-primary { background-color: var(--color-primary); }
.bg-secondary { background-color: var(--color-background); }
.bg-white { background-color: var(--color-surface); }
.bg-gray { background-color: var(--ios-gray6); }

/* 通用边框 */
.border { border: 2rpx solid var(--color-border); }
.border-top { border-top: 2rpx solid var(--color-border); }
.border-bottom { border-bottom: 2rpx solid var(--color-border); }
.border-left { border-left: 2rpx solid var(--color-border); }
.border-right { border-right: 2rpx solid var(--color-border); }

/* 通用字体大小 */
.text-xs { font-size: 24rpx; }
.text-sm { font-size: 28rpx; }
.text-base { font-size: 32rpx; }
.text-lg { font-size: 36rpx; }
.text-xl { font-size: 40rpx; }
.text-2xl { font-size: 48rpx; }

/* 通用字体粗细 */
.font-normal { font-weight: normal; }
.font-medium { font-weight: 500; }
.font-bold { font-weight: 700; }

/* 通用文本对齐 */
.text-left { text-align: left; }
.text-center { text-align: center; }
.text-right { text-align: right; }

/* 通用宽度 */
.w-full { width: 100%; }
.w-1-2 { width: 50%; }
.w-1-3 { width: 33.333%; }
.w-1-4 { width: 25%; }

/* 通用高度 */
.h-full { height: 100%; }
.h-screen { height: 100vh; }

/* 通用位置 */
.relative { position: relative; }
.absolute { position: absolute; }
.fixed { position: fixed; }

/* 通用z-index */
.z-10 { z-index: 10; }
.z-20 { z-index: 20; }
.z-30 { z-index: 30; }
.z-40 { z-index: 40; }
.z-50 { z-index: 50; }

/* Flex 布局 */
.flex { display: flex; }
.flex-column { flex-direction: column; }
.flex-center { align-items: center; justify-content: center; }
.flex-between { justify-content: space-between; align-items: center; }
.flex-around { justify-content: space-around; align-items: center; }
.flex-1 { flex: 1; }

/* 文本溢出 */
.text-ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.text-ellipsis-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

/* 按钮变体 */
.btn-primary { background: var(--color-primary); color: white; }
.btn-success { background: var(--color-success); color: white; }
.btn-warning { background: var(--color-warning); color: white; }
.btn-danger { background: var(--color-danger); color: white; }
.btn-outline { background: transparent; border: 2rpx solid var(--color-border); color: var(--color-text-primary); }

/* 标签样式 - iOS Style */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: var(--radius-full);
}

.tag-primary { background: rgba(0, 122, 255, 0.1); color: var(--color-primary); }
.tag-success { background: rgba(52, 199, 89, 0.1); color: var(--color-success); }
.tag-warning { background: rgba(255, 149, 0, 0.1); color: var(--color-warning); }
.tag-danger { background: rgba(255, 59, 48, 0.1); color: var(--color-danger); }

/* 状态栏样式 */
.status-bar {
  height: 88rpx;
  padding: 0 var(--spacing-md);
  background: linear-gradient(135deg, var(--color-primary) 0%, #0055BB 100%);
  color: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 导航栏样式 */
.navbar {
  height: 88rpx;
  padding: 0 var(--spacing-md);
  background: var(--color-surface);
  border-bottom: 2rpx solid var(--color-separator);
  display: flex;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 100;
}

/* 列表项样式 - iOS Style */
.list-item {
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--color-surface);
  border-radius: 0;
  margin-bottom: 2rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background var(--transition-fast);
}

.list-item:active {
  background: var(--ios-gray6);
}

/* 表单样式 - iOS Style */
.form-group {
  margin-bottom: var(--spacing-lg);
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-xs);
}

/* 徽章样式 */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  background: var(--color-danger);
  color: white;
}