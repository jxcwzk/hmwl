<view class="container">
  <view wx:if="{{!isLoggedIn}}" class="login-prompt">
    <view class="prompt-icon">📦</view>
    <text class="prompt-text">请先登录查看订单</text>
    <button class="login-btn" bindtap="goToLogin">去登录</button>
  </view>

  <view wx:else>
    <!-- 订单统计横幅 -->
    <view class="order-stats-banner">
      <view class="stats-item" bindtap="switchTab" data-tab="all">
        <text class="stats-value">{{stats.all}}</text>
        <text class="stats-label">全部</text>
      </view>
      <view class="stats-item" bindtap="switchTab" data-tab="pending">
        <text class="stats-value">{{stats.pending}}</text>
        <text class="stats-label">待处理</text>
      </view>
      <view class="stats-item" bindtap="switchTab" data-tab="pickup">
        <text class="stats-value">{{stats.pickup}}</text>
        <text class="stats-label">待取件</text>
      </view>
      <view class="stats-item" bindtap="switchTab" data-tab="transport">
        <text class="stats-value">{{stats.transport}}</text>
        <text class="stats-label">运输中</text>
      </view>
      <view class="stats-item" bindtap="switchTab" data-tab="completed">
        <text class="stats-value">{{stats.completed}}</text>
        <text class="stats-label">已完成</text>
      </view>
    </view>

    <view class="order-tabs">
      <view class="order-tab {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
      <view class="order-tab {{activeTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">待付款</view>
      <view class="order-tab {{activeTab === 'pickup' ? 'active' : ''}}" bindtap="switchTab" data-tab="pickup">待取件</view>
      <view class="order-tab {{activeTab === 'transport' ? 'active' : ''}}" bindtap="switchTab" data-tab="transport">运输中</view>
      <view class="order-tab {{activeTab === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-tab="completed">已完成</view>
    </view>

    <view class="order-list">
      <view class="order-item" wx:for="{{orderList}}" wx:key="id" bindtap="viewOrderDetail" data-orderno="{{item.orderNo}}">
        <view class="order-header">
          <view class="order-header-left">
            <text class="order-time">{{item.createTime}}</text>
            <text class="order-no">单号：{{item.orderNo}}</text>
          </view>
          <view class="order-status status-{{item.status}}">
            <text class="status-text">{{item.status === 0 ? '待付款' : item.status === 1 ? '已付款' : item.status === 2 ? '运输中' : item.status === 3 ? '已签收' : '已完成'}}</text>
          </view>
        </view>
        <view class="order-content">
          <view class="route-info">
            <view class="route-point sender">
              <text class="route-icon">📤</text>
              <view class="route-detail">
                <text class="route-name">{{item.senderName}}</text>
                <text class="route-phone">{{item.senderPhone}}</text>
              </view>
            </view>
            <view class="route-arrow">→</view>
            <view class="route-point receiver">
              <text class="route-icon">📥</text>
              <view class="route-detail">
                <text class="route-name">{{item.receiverName}}</text>
                <text class="route-phone">{{item.receiverPhone}}</text>
              </view>
            </view>
          </view>
          <view class="order-info">
            <text class="info-label">货物：</text>
            <text class="info-value">{{item.goodsName}} × {{item.quantity}}</text>
          </view>
          <view class="order-info" wx:if="{{userInfo.userType === 1 || userInfo.userType === 4}}">
            <text class="info-label">基础费用：</text>
            <text class="info-value">¥{{item.baseFee || 0}}</text>
          </view>
          <view class="order-info" wx:if="{{userInfo.userType === 1 || userInfo.userType === 2}}">
            <text class="info-label">客户报价：</text>
            <text class="info-value price">¥{{item.totalFee || 0}}</text>
          </view>
          <view class="order-info" wx:if="{{userInfo.userType === 1 || userInfo.userType === 2 || userInfo.userType === 4}}">
            <text class="info-label">物流进度：</text>
            <text class="info-value">{{item.logisticsProgress || '待更新'}}</text>
          </view>
        </view>
        <view class="order-footer">
          <text class="order-cost" wx:if="{{userInfo.userType === 2}}">¥{{item.totalFee || 0}}</text>
          <view class="order-actions">
            <!-- 管理员操作 -->
            <view wx:if="{{userInfo.userType === 1}}">
              <button class="action-btn secondary" catchtap="assignDriver" data-order="{{item}}">指派司机</button>
              <button class="action-btn secondary" catchtap="assignNetwork" data-order="{{item}}">指派网点</button>
              <button class="action-btn primary" catchtap="viewOrderDetail" data-orderno="{{item.orderNo}}">查看详情</button>
            </view>
            
            <!-- 网点操作 -->
            <view wx:if="{{userInfo.userType === 4}}">
              <button class="action-btn secondary" catchtap="providePrice" data-order="{{item}}">提供报价</button>
              <button class="action-btn secondary" catchtap="updateLogistics" data-order="{{item}}">更新物流</button>
              <button class="action-btn primary" catchtap="viewOrderDetail" data-orderno="{{item.orderNo}}">查看详情</button>
            </view>
            
            <!-- 司机操作 -->
            <view wx:if="{{userInfo.userType === 3}}">
              <button class="action-btn primary" catchtap="viewOrderDetail" data-orderno="{{item.orderNo}}">查看详情</button>
            </view>
            
            <!-- 客户操作 -->
            <view wx:if="{{userInfo.userType === 2}}">
              <button class="action-btn secondary" catchtap="cancelOrder" data-index="{{index}}">取消</button>
              <button class="action-btn primary" catchtap="payOrder" data-order="{{item}}">{{item.status === 0 ? '付款' : '查看物流'}}</button>
            </view>
          </view>
        </view>
      </view>

      <view class="loading-more" wx:if="{{loading}}">
        <text>加载中...</text>
      </view>

      <view class="empty-order" wx:if="{{orderList.length === 0 && !loading}}">
        <text>暂无订单</text>
      </view>
    </view>
  </view>
</view>
