.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  background-color: white;
  margin: 20rpx;
  border-radius: 16rpx;
}

.prompt-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.prompt-text {
  font-size: 16px;
  color: #666;
  margin-bottom: 30rpx;
}

.login-btn {
  background: linear-gradient(135deg, #E60012 0%, #FF6B6B 100%);
  color: white;
  font-size: 14px;
  padding: 16rpx 60rpx;
  border-radius: 30rpx;
  border: none;
}

/* 订单统计横幅 */
.order-stats-banner {
  display: flex;
  background: linear-gradient(135deg, #E60012 0%, #FF6B6B 100%);
  padding: 24rpx 16rpx;
  margin: 16rpx;
  border-radius: 16rpx;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.stats-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 10rpx;
  height: 40rpx;
  width: 1rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.stats-value {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.stats-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

.loading-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 12px;
}

/* 订单分类 */
.order-tabs {
  display: flex;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.order-tab {
  flex: 1;
  text-align: center;
  padding: 15rpx 0;
  font-size: 14px;
  color: #666;
  position: relative;
}

.order-tab.active {
  color: #E60012;
  font-weight: bold;
}

.order-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 3rpx;
  background-color: #E60012;
}

/* 订单列表 */
.order-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.order-item {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.order-item:active {
  opacity: 0.95;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.order-header-left {
  display: flex;
  flex-direction: column;
}

.order-time {
  font-size: 22rpx;
  color: #999;
}

.order-no {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}

.order-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-0 {
  background-color: #FFF2E6;
  color: #FA8C16;
}

.status-1 {
  background-color: #E6F7FF;
  color: #1890FF;
}

.status-2 {
  background-color: #F0F5FF;
  color: #2F54EB;
}

.status-3, .status-4 {
  background-color: #F6FFED;
  color: #52C41A;
}

/* 路由信息 */
.route-info {
  display: flex;
  align-items: center;
  background-color: #F9FAFB;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.route-point {
  display: flex;
  align-items: center;
  flex: 1;
}

.route-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.route-detail {
  display: flex;
  flex-direction: column;
}

.route-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.route-phone {
  font-size: 22rpx;
  color: #999;
  margin-top: 2rpx;
}

.route-arrow {
  font-size: 28rpx;
  color: #999;
  margin: 0 16rpx;
}

.order-content {
  margin-bottom: 16rpx;
}

.order-number {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 10rpx;
}

.order-service {
  display: block;
  font-size: 12px;
  color: #666;
  margin-bottom: 10rpx;
}

.order-info {
  display: flex;
  margin-bottom: 8rpx;
  align-items: center;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  width: 140rpx;
}

.info-value {
  font-size: 24rpx;
  color: #666;
  flex: 1;
}

.info-value.price {
  color: #E60012;
  font-weight: 500;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-cost {
  font-size: 32rpx;
  font-weight: bold;
  color: #E60012;
}

.order-actions {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.action-btn {
  font-size: 22rpx;
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: 26rpx;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #E60012 0%, #FF6B6B 100%);
  color: white;
}

.action-btn.secondary {
  background-color: white;
  color: #666;
  border: 1rpx solid #e5e5e5;
}

.action-btn:active {
  opacity: 0.85;
}

.action-btn::after {
  border: none;
}

.empty-order {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 14px;
  background-color: white;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}