.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 订单分类 */
.order-tabs {
  display: flex;
  background-color: white;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.order-tab {
  flex: 1;
  text-align: center;
  padding: 15rpx 0;
  font-size: 14px;
  color: #666;
  position: relative;
}

.order-tab.active {
  color: #E60012;
  font-weight: bold;
}

.order-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 3rpx;
  background-color: #E60012;
}

/* 订单列表 */
.order-list {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.order-item {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-time {
  font-size: 12px;
  color: #999;
}

.order-status {
  font-size: 14px;
  font-weight: bold;
  color: #E60012;
}

.order-content {
  margin-bottom: 15rpx;
}

.order-number {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 10rpx;
}

.order-service {
  display: block;
  font-size: 12px;
  color: #666;
  margin-bottom: 10rpx;
}

.order-info {
  display: flex;
  margin-bottom: 5rpx;
}

.info-label {
  font-size: 12px;
  color: #999;
  width: 80rpx;
}

.info-value {
  font-size: 12px;
  color: #666;
  flex: 1;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.order-cost {
  font-size: 16px;
  font-weight: bold;
  color: #E60012;
}

.order-actions {
  display: flex;
  gap: 10rpx;
}

.action-btn {
  font-size: 12px;
  height: 40rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
}

.action-btn.primary {
  background-color: #E60012;
  color: white;
}

.action-btn.secondary {
  background-color: white;
  color: #666;
  border: 1rpx solid #ddd;
}

.action-btn::after {
  border: none;
}

.empty-order {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 14px;
  background-color: white;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}