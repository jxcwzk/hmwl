<view class="container">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-input" bindtap="navigateToQuery">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">请输入快递单号</text>
    </view>
    <view class="scan-btn" bindtap="scanCode">
      <text class="scan-icon">📷</text>
    </view>
  </view>

  <!-- 用户状态横幅 -->
  <view class="user-banner" wx:if="{{isLoggedIn && userInfo}}">
    <view class="banner-content">
      <view class="banner-avatar">{{userInfo.username ? userInfo.username[0] : '用'}}</view>
      <view class="banner-info">
        <text class="banner-name">{{userInfo.username || '用户'}}</text>
        <text class="banner-role">{{userTypeText}}</text>
      </view>
    </view>
    <view class="banner-stats">
      <view class="stat-item">
        <text class="stat-value">{{orderStats.total || 0}}</text>
        <text class="stat-label">总订单</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{orderStats.pending || 0}}</text>
        <text class="stat-label">进行中</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{orderStats.completed || 0}}</text>
        <text class="stat-label">已完成</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:if="{{error}}" class="error-container">
    <text class="error-icon">⚠️</text>
    <text class="error-text">加载失败</text>
    <button class="retry-btn" bindtap="retryLoad">重新加载</button>
  </view>

  <!-- 内容区域 -->
  <view wx:if="{{!loading && !error}}">
    <!-- 核心功能区 -->
    <view class="core-functions">
      <view class="function-item" bindtap="navigateToSend" aria-label="寄件">
        <view class="function-icon-wrapper send-icon">
          <text class="function-icon">📦</text>
        </view>
        <text class="function-text">寄件</text>
      </view>
      <view class="function-item" bindtap="navigateToQuery" aria-label="查件">
        <view class="function-icon-wrapper query-icon">
          <text class="function-icon">🔍</text>
        </view>
        <text class="function-text">查件</text>
      </view>
      <view class="function-item" bindtap="navigateToOrder" aria-label="我的订单">
        <view class="function-icon-wrapper order-icon">
          <text class="function-icon">📋</text>
        </view>
        <text class="function-text">我的订单</text>
      </view>
      <view class="function-item" bindtap="navigateToNetwork" aria-label="网点查询">
        <view class="function-icon-wrapper network-icon">
          <text class="function-icon">🏪</text>
        </view>
        <text class="function-text">网点查询</text>
      </view>
    </view>

    <!-- 高优先级功能快捷入口 -->
    <view class="quick-entry-section" wx:if="{{isLoggedIn}}">
      <view class="section-header">
        <text class="section-title">快捷服务</text>
      </view>
      <view class="quick-entry-grid">
        <view class="quick-entry-item" bindtap="navigateToDriverOrders" wx:if="{{userInfo && userInfo.userType === 3}}">
          <view class="quick-icon driver-bg">
            <text class="quick-icon-text">🚚</text>
          </view>
          <text class="quick-text">司机接单</text>
        </view>
        <view class="quick-entry-item" bindtap="navigateToSettlement" wx:if="{{userInfo && (userInfo.userType === 1 || userInfo.userType === 4)}}">
          <view class="quick-icon settlement-bg">
            <text class="quick-icon-text">💰</text>
          </view>
          <text class="quick-text">结算中心</text>
        </view>
        <view class="quick-entry-item" bindtap="navigateToStatistics" wx:if="{{userInfo && userInfo.userType === 1}}">
          <view class="quick-icon stats-bg">
            <text class="quick-icon-text">📊</text>
          </view>
          <text class="quick-text">运营报表</text>
        </view>
        <view class="quick-entry-item" bindtap="navigateToCustomer">
          <view class="quick-icon customer-bg">
            <text class="quick-icon-text">👥</text>
          </view>
          <text class="quick-text">客户档案</text>
        </view>
      </view>
    </view>

    <!-- 物流动态 -->
    <view class="logistics-section">
      <view class="section-header">
        <text class="section-title">物流动态</text>
        <text class="section-more" bindtap="navigateToOrder">查看全部</text>
      </view>
      <view class="logistics-list">
        <view class="logistics-item" wx:for="{{logisticsList}}" wx:key="number">
          <view class="logistics-info">
            <text class="express-number">{{item.number}}</text>
            <text class="express-status">{{item.status}}</text>
          </view>
          <text class="logistics-detail">{{item.detail}}</text>
        </view>
        <view class="logistics-empty" wx:if="{{logisticsList.length === 0}}">
          <text>暂无物流动态</text>
        </view>
      </view>
    </view>

    <!-- 活动推荐 -->
    <view class="activity-section">
      <view class="section-header">
        <text class="section-title">活动推荐</text>
        <text class="section-more" bindtap="navigateToActivity">查看全部</text>
      </view>
      <view class="activity-list">
        <view class="activity-item" wx:for="{{activityList}}" wx:key="index">
          <view class="activity-content">
            <text class="activity-title">{{item.title}}</text>
            <text class="activity-desc">{{item.desc}}</text>
          </view>
          <view class="activity-tag">{{item.tag}}</view>
        </view>
      </view>
    </view>
  </view>
</view>