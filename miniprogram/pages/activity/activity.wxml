<view class="container">
  <!-- 优惠券 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">优惠券</text>
    </view>
    <view class="coupon-tabs">
      <view class="coupon-tab {{activeTab === 'available' ? 'active' : ''}}" bindtap="switchTab" data-tab="available">可用</view>
      <view class="coupon-tab {{activeTab === 'used' ? 'active' : ''}}" bindtap="switchTab" data-tab="used">已使用</view>
      <view class="coupon-tab {{activeTab === 'expired' ? 'active' : ''}}" bindtap="switchTab" data-tab="expired">已过期</view>
    </view>
    <view class="coupon-list">
      <view class="coupon-item" wx:for="{{coupons}}" wx:key="index">
        <view class="coupon-value">
          <text class="value-symbol">¥</text>
          <text class="value-number">{{item.value}}</text>
        </view>
        <view class="coupon-info">
          <text class="coupon-title">{{item.title}}</text>
          <text class="coupon-desc">{{item.desc}}</text>
          <text class="coupon-expire">有效期至：{{item.expire}}</text>
        </view>
        <view class="coupon-status" wx:if="activeTab === 'used'">已使用</view>
        <view class="coupon-status expired" wx:if="activeTab === 'expired'">已过期</view>
      </view>
      <view class="empty-coupon" wx:if="coupons.length === 0">
        <text>暂无{{activeTab === 'available' ? '可用' : activeTab === 'used' ? '已使用' : '已过期'}}优惠券</text>
      </view>
    </view>
  </view>

  <!-- 促销活动 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">促销活动</text>
    </view>
    <view class="activity-list">
      <view class="activity-item" wx:for="{{activities}}" wx:key="index">
        <view class="activity-content">
          <text class="activity-title">{{item.title}}</text>
          <text class="activity-desc">{{item.desc}}</text>
          <text class="activity-time">活动时间：{{item.time}}</text>
        </view>
        <view class="activity-tag">{{item.tag}}</view>
      </view>
    </view>
  </view>

  <!-- 积分商城 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">积分商城</text>
    </view>
    <view class="points-info">
      <text class="points-label">我的积分：</text>
      <text class="points-value">{{points}}</text>
    </view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{goodsList}}" wx:key="index">
        <view class="goods-icon">{{item.icon}}</view>
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-price">{{item.points}}积分</text>
        </view>
        <button class="exchange-btn" bindtap="exchangeGoods" data-index="{{index}}">兑换</button>
      </view>
    </view>
  </view>
</view>