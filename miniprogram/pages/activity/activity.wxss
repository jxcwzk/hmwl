.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.section {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

/* 优惠券 */
.coupon-tabs {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.coupon-tab {
  flex: 1;
  text-align: center;
  padding: 15rpx 0;
  font-size: 14px;
  color: #666;
  position: relative;
}

.coupon-tab.active {
  color: #E60012;
  font-weight: bold;
}

.coupon-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 3rpx;
  background-color: #E60012;
}

.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.coupon-item {
  display: flex;
  align-items: center;
  padding: 15rpx;
  border: 1rpx solid #f0f0f0;
  border-radius: 5rpx;
  position: relative;
}

.coupon-value {
  display: flex;
  align-items: baseline;
  margin-right: 20rpx;
  min-width: 100rpx;
}

.value-symbol {
  font-size: 14px;
  color: #E60012;
  margin-right: 5rpx;
}

.value-number {
  font-size: 24px;
  font-weight: bold;
  color: #E60012;
}

.coupon-info {
  flex: 1;
}

.coupon-title {
  font-size: 14px;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
  display: block;
}

.coupon-desc {
  font-size: 12px;
  color: #666;
  margin-bottom: 5rpx;
  display: block;
}

.coupon-expire {
  font-size: 12px;
  color: #999;
  display: block;
}

.coupon-status {
  position: absolute;
  top: 0;
  right: 0;
  background-color: #999;
  color: white;
  font-size: 12px;
  padding: 5rpx 10rpx;
  border-radius: 0 5rpx 0 5rpx;
}

.coupon-status.expired {
  background-color: #ccc;
}

.empty-coupon {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 14px;
}

/* 促销活动 */
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.activity-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 5rpx;
  border-left: 4rpx solid #E60012;
}

.activity-content {
  flex: 1;
}

.activity-title {
  font-size: 14px;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
  display: block;
}

.activity-desc {
  font-size: 12px;
  color: #666;
  margin-bottom: 5rpx;
  display: block;
}

.activity-time {
  font-size: 12px;
  color: #999;
  display: block;
}

.activity-tag {
  background-color: #E60012;
  color: white;
  font-size: 12px;
  padding: 5rpx 10rpx;
  border-radius: 10rpx;
}

/* 积分商城 */
.points-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 5rpx;
}

.points-label {
  font-size: 14px;
  color: #666;
  margin-right: 10rpx;
}

.points-value {
  font-size: 18px;
  font-weight: bold;
  color: #E60012;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 15rpx;
  border: 1rpx solid #f0f0f0;
  border-radius: 5rpx;
}

.goods-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 14px;
  color: #333;
  margin-bottom: 5rpx;
  display: block;
}

.goods-price {
  font-size: 12px;
  color: #E60012;
  font-weight: bold;
  display: block;
}

.exchange-btn {
  background-color: #E60012;
  color: white;
  font-size: 12px;
  height: 40rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
}

.exchange-btn::after {
  border: none;
}