.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 200rpx;
}

.status-section {
  background-color: #E60012;
  padding: 40rpx 30rpx;
  text-align: center;
}

.status-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
}

.status-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.status-value.pending {
  color: #fa8c16;
}

.status-value.accepted {
  color: #1890ff;
}

.status-value.picked {
  color: #52c41a;
}

.status-value.delivering {
  color: #eb2f96;
}

.status-value.delivered {
  color: #722ed1;
}

.status-value.completed {
  color: #fff;
}

.logistics-progress {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 20rpx;
  padding: 16rpx;
  background-color: rgba(0, 0, 0, 0.1);
  border-radius: 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  padding: 30rpx;
}

.route-section, .goods-section, .receipt-section {
  background-color: #fff;
  margin-bottom: 20rpx;
}

.route-card, .goods-card, .receipt-card {
  padding: 0 30rpx 30rpx;
}

.route-point {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
}

.point-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.point-icon.start {
  background-color: #E60012;
}

.point-icon.end {
  background-color: #52c41a;
}

.point-content {
  flex: 1;
}

.point-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.point-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.point-phone {
  font-size: 26rpx;
  color: #666;
}

.point-address {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.route-divider {
  width: 4rpx;
  height: 60rpx;
  background-color: #ddd;
  margin-left: 28rpx;
}

.goods-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-item .label {
  font-size: 26rpx;
  color: #999;
}

.goods-item .value {
  font-size: 26rpx;
  color: #333;
}

.receipt-card {
  padding-bottom: 30rpx;
}

.receipt-image {
  width: 300rpx;
  height: 300rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  overflow: hidden;
}

.receipt-image image {
  width: 100%;
  height: 100%;
}

.upload-receipt {
  width: 300rpx;
  height: 300rpx;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-receipt .icon {
  font-size: 60rpx;
  color: #ddd;
  line-height: 1;
}

.upload-receipt .text {
  font-size: 26rpx;
  color: #999;
  margin-top: 16rpx;
}

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.status-flow {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.flow-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  background-color: #f5f5f5;
  color: #999;
  border: none;
  border-radius: 8rpx;
}

.flow-btn.active {
  background-color: #E60012;
  color: #fff;
}

.remark-section {
  display: flex;
  gap: 20rpx;
}

.remark-input {
  flex: 1;
  height: 70rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.remark-btn {
  width: 160rpx;
  height: 70rpx;
  line-height: 70rpx;
  background-color: #E60012;
  color: #fff;
  font-size: 26rpx;
  border: none;
  border-radius: 8rpx;
}
