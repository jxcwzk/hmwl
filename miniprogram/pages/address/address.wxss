.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.tabs {
  display: flex;
  background-color: white;
  padding: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 30rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}

.tab.active {
  color: #07c160;
  border-bottom-color: #07c160;
  font-weight: bold;
}

.list {
  margin-top: 20rpx;
  background-color: white;
}

.item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.phone {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

.address {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.actions {
  display: flex;
  gap: 20rpx;
}

.edit, .delete {
  font-size: 28rpx;
  padding: 10rpx 20rpx;
}

.edit {
  color: #07c160;
}

.delete {
  color: #ff4d4f;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}

.add-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50rpx;
  right: 50rpx;
  height: 90rpx;
  background-color: #07c160;
  color: white;
  font-size: 32rpx;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  width: 600rpx;
  background-color: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  border-bottom: 1rpx solid #eee;
}

.modal-body {
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.input, .textarea {
  width: 100%;
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  height: 150rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.cancel, .confirm {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  font-size: 30rpx;
  border: none;
  border-radius: 0;
}

.cancel {
  background-color: #f5f5f5;
  color: #666;
}

.confirm {
  background-color: #07c160;
  color: white;
}
