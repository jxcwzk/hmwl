<view class="container">
  <view class="section">
    <view class="section-header">
      <text class="section-title">发件人信息</text>
      <view class="header-actions">
        <text class="action-btn" bindtap="addSender">新增</text>
      </view>
    </view>
    <view class="info-form">
      <view class="form-item">
        <text class="form-label">选择发件人</text>
        <picker class="form-picker" bindchange="bindSenderChange" value="{{senderIndex}}" range="{{senderList}}" range-key="customerName">
          <view class="picker-text">{{senderIndex >= 0 ? senderList[senderIndex].customerName : '请选择发件人'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="请输入姓名" value="{{sender.name}}" bindinput="bindSenderInput" data-field="name" />
      </view>
      <view class="form-item">
        <text class="form-label">电话</text>
        <input class="form-input" placeholder="请输入电话" value="{{sender.phone}}" bindinput="bindSenderInput" data-field="phone" />
      </view>
      <view class="form-item">
        <text class="form-label">地址</text>
        <input class="form-input" placeholder="请输入地址" value="{{sender.address}}" bindinput="bindSenderInput" data-field="address" />
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">收件人信息</text>
      <view class="header-actions">
        <text class="action-btn" bindtap="addReceiver">新增</text>
      </view>
    </view>
    <view class="info-form">
      <view class="form-item">
        <text class="form-label">选择收件人</text>
        <picker class="form-picker" bindchange="bindReceiverChange" value="{{receiverIndex}}" range="{{receiverList}}" range-key="customerName">
          <view class="picker-text">{{receiverIndex >= 0 ? receiverList[receiverIndex].customerName : '请选择收件人'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="请输入姓名" value="{{receiver.name}}" bindinput="bindReceiverInput" data-field="name" />
      </view>
      <view class="form-item">
        <text class="form-label">电话</text>
        <input class="form-input" placeholder="请输入电话" value="{{receiver.phone}}" bindinput="bindReceiverInput" data-field="phone" />
      </view>
      <view class="form-item">
        <text class="form-label">地址</text>
        <input class="form-input" placeholder="请输入地址" value="{{receiver.address}}" bindinput="bindReceiverInput" data-field="address" />
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">货物信息</text>
    <view class="info-form">
      <view class="form-item form-item-full">
        <text class="form-label">描述</text>
        <input class="form-input" placeholder="请输入货物描述" value="{{goods.description}}" bindinput="bindGoodsInput" data-field="description" />
      </view>
      <view class="form-item">
        <text class="form-label">重量(kg)</text>
        <input class="form-input" type="digit" placeholder="请输入重量" value="{{goods.weight}}" bindinput="bindGoodsInput" data-field="weight" />
      </view>
      <view class="form-item">
        <text class="form-label">体积(m³)</text>
        <input class="form-input" type="digit" placeholder="请输入体积" value="{{goods.volume}}" bindinput="bindGoodsInput" data-field="volume" />
      </view>
      <view class="form-item form-item-full">
        <text class="form-label">备注</text>
        <input class="form-input" placeholder="请输入备注" value="{{goods.remark}}" bindinput="bindGoodsInput" data-field="remark" />
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">货物照片</text>
    <view class="goods-photos">
      <view class="photo-list">
        <view class="photo-item" wx:for="{{goodsPhotos}}" wx:key="index">
          <image class="photo-img" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}"></image>
          <view class="photo-delete" bindtap="deletePhoto" data-index="{{index}}">×</view>
        </view>
        <view class="photo-add" bindtap="chooseImage" wx:if="{{goodsPhotos.length < maxPhotoCount}}">
          <text class="photo-add-icon">+</text>
          <text class="photo-add-text">拍照/相册</text>
        </view>
      </view>
      <text class="photo-tip">最多上传{{maxPhotoCount}}张照片</text>
    </view>
  </view>

  <button class="submit-btn" bindtap="submitOrder">确认寄件</button>

  <view class="modal" wx:if="{{showModal}}">
    <view class="modal-content">
      <view class="modal-header">{{modalType === 'edit' ? '编辑' : '新增'}}{{modalTitle}}</view>
      <view class="modal-body">
        <view class="form-item">
          <text class="label">姓名</text>
          <input class="input" value="{{modalForm.customerName}}" bindinput="onModalInput" data-field="customerName" placeholder="请输入姓名" />
        </view>
        <view class="form-item">
          <text class="label">电话</text>
          <input class="input" value="{{modalForm.phone}}" bindinput="onModalInput" data-field="phone" type="number" placeholder="请输入电话" />
        </view>
        <view class="form-item">
          <text class="label">地址</text>
          <textarea class="textarea" value="{{modalForm.address}}" bindinput="onModalInput" data-field="address" placeholder="请输入地址" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="cancel" bindtap="closeModal">取消</button>
        <button class="confirm" bindtap="submitModal">确定</button>
      </view>
    </view>
  </view>
</view>
