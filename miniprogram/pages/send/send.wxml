<view class="container">
  <!-- 寄件人信息 -->
  <view class="contact-section">
    <view class="contact-item sender">
      <view class="contact-icon sender-icon">寄</view>
      <view class="contact-content">
        <view class="contact-main" wx:if="{{senderIndex >= 0}}">
          <view class="contact-header">
            <text class="contact-name">{{senderList[senderIndex].customerName}}</text>
            <text class="contact-phone">{{senderList[senderIndex].phone || senderList[senderIndex].contact}}</text>
          </view>
          <view class="contact-address">{{senderList[senderIndex].address}}</view>
        </view>
        <picker class="contact-picker" bindchange="bindSenderChange" value="{{senderIndex}}" range="{{senderList}}" range-key="customerName" wx:else>
          <view class="picker-text">请选择发件人</view>
        </picker>
      </view>
      <text class="address-book-btn" bindtap="addSender">地址簿</text>
    </view>
  </view>

  <!-- 收件人信息 -->
  <view class="contact-section">
    <view class="contact-item receiver">
      <view class="contact-icon receiver-icon">收</view>
      <view class="contact-content">
        <view class="contact-main" wx:if="{{receiverIndex >= 0}}">
          <view class="contact-header">
            <text class="contact-name">{{receiverList[receiverIndex].customerName}}</text>
            <text class="contact-phone">{{receiverList[receiverIndex].phone || receiverList[receiverIndex].contact}}</text>
          </view>
          <view class="contact-address">{{receiverList[receiverIndex].address}}</view>
        </view>
        <picker class="contact-picker" bindchange="bindReceiverChange" value="{{receiverIndex}}" range="{{receiverList}}" range-key="customerName" wx:else>
          <view class="picker-text">请选择收件人</view>
        </picker>
      </view>
      <text class="address-book-btn" bindtap="addReceiver">地址簿</text>
    </view>
  </view>

  <!-- 货物信息 -->
  <view class="section">
    <view class="goods-section">
      <text class="section-label">物品信息</text>
      <text class="required-mark">必填</text>
      <view class="goods-inputs">
        <view class="form-item form-item-full">
          <input class="form-input" placeholder="请输入货物描述" value="{{goods.description}}" bindinput="bindGoodsInput" data-field="description" />
        </view>
        <view class="form-item-row">
          <view class="form-item half">
            <text class="form-label">重量(kg)</text>
            <input class="form-input" type="digit" placeholder="请输入重量" value="{{goods.weight}}" bindinput="bindGoodsInput" data-field="weight" />
          </view>
          <view class="form-item half">
            <text class="form-label">体积(m³)</text>
            <input class="form-input" type="digit" placeholder="请输入体积" value="{{goods.volume}}" bindinput="bindGoodsInput" data-field="volume" />
          </view>
        </view>
        <view class="form-item form-item-full">
          <input class="form-input" placeholder="请输入备注" value="{{goods.remark}}" bindinput="bindGoodsInput" data-field="remark" />
        </view>
      </view>
    </view>
  </view>

  <!-- 货物照片 -->
  <view class="section">
    <view class="photos-section">
      <text class="section-label">货物照片</text>
      <view class="photo-list">
        <view class="photo-item" wx:for="{{goodsPhotos}}" wx:key="index">
          <image class="photo-img" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}"></image>
          <view class="photo-delete" bindtap="deletePhoto" data-index="{{index}}">×</view>
        </view>
        <view class="photo-add" bindtap="chooseImage" wx:if="{{goodsPhotos.length < maxPhotoCount}}">
          <text class="photo-add-icon">+</text>
          <text class="photo-add-text">拍照/相册</text>
        </view>
      </view>
      <text class="photo-tip">最多上传{{maxPhotoCount}}张照片</text>
    </view>
  </view>

  <!-- 付款方式和预估总价 -->
  <view class="section">
    <view class="payment-price-section">
      <view class="payment-option">
        <text class="section-label">付款方式</text>
        <text class="payment-text">寄付现结</text>
        <text class="arrow-right">></text>
      </view>
      <view class="price-info">
        <text class="price-label">预估总价</text>
        <text class="price-value">¥ --</text>
        <text class="price-detail">明细</text>
      </view>
    </view>
  </view>

  <!-- 下单按钮 -->
  <view class="submit-section">
    <view class="agreement">
      <checkbox class="checkbox"></checkbox>
      <text class="agreement-text">阅读并同意《电子运单契约条款》</text>
    </view>
    <button class="submit-btn" bindtap="submitOrder">下单</button>
  </view>

  <!-- 新增/编辑联系人模态框 -->
  <view class="modal" wx:if="{{showModal}}">
    <view class="modal-content">
      <view class="modal-header">{{modalType === 'edit' ? '编辑' : '新增'}}{{modalTitle}}</view>
      <view class="modal-body">
        <view class="form-item">
          <text class="label">姓名</text>
          <input class="input" value="{{modalForm.customerName}}" bindinput="onModalInput" data-field="customerName" placeholder="请输入姓名" />
        </view>
        <view class="form-item">
          <text class="label">电话</text>
          <input class="input" value="{{modalForm.phone}}" bindinput="onModalInput" data-field="phone" type="number" placeholder="请输入电话" />
        </view>
        <view class="form-item">
          <text class="label">地址</text>
          <textarea class="textarea" value="{{modalForm.address}}" bindinput="onModalInput" data-field="address" placeholder="请输入地址" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="cancel" bindtap="closeModal">取消</button>
        <button class="confirm" bindtap="submitModal">确定</button>
      </view>
    </view>
  </view>
</view>
