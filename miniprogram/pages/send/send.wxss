.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 联系信息部分 */
.contact-section {
  background-color: white;
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 80rpx;
}

.contact-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.contact-icon.sender-icon {
  background: linear-gradient(135deg, #E60012 0%, #FF6B6B 100%);
}

.contact-icon.receiver-icon {
  background: linear-gradient(135deg, #52C41A 0%, #95DE64 100%);
}

.icon-text {
  font-size: 24rpx;
  font-weight: bold;
  color: white;
}

.contact-content {
  flex: 1;
  min-width: 0;
}

.contact-main {
  width: 100%;
}

.contact-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.contact-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.contact-phone {
  font-size: 26rpx;
  color: #666;
}

.contact-address {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  word-break: break-all;
}

.address-book-btn {
  flex-shrink: 0;
}

.btn-text {
  font-size: 24rpx;
  color: #E60012;
  background-color: #FFF2E6;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
}

.contact-picker {
  width: 100%;
  height: 60rpx;
  display: flex;
  align-items: center;
}

.picker-text {
  font-size: 28rpx;
  color: #999;
}

/* 通用区块 */
.section {
  background-color: white;
  margin-bottom: 16rpx;
  padding: 24rpx;
}

/* 货物信息 */
.goods-section {
  margin-top: 0;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.goods-inputs {
  margin-top: 16rpx;
}

.form-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.form-item-full {
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
}

.form-label {
  width: 140rpx;
  font-size: 26rpx;
  color: #666;
}

.form-input {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  background-color: #fafafa;
}

.form-input:focus {
  border-color: #E60012;
  background-color: white;
}

.form-item-full .form-input {
  width: 100%;
}

/* 表单行布局 */
.form-item-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 15rpx;
}

.form-item.half {
  flex: 1;
}

.form-item.half .form-input {
  width: 100%;
}

/* 货物照片 */
.photos-section {
  margin-top: 10rpx;
}

.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 15rpx;
}

.photo-item {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 5rpx;
  right: 5rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: white;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.photo-add {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed #ddd;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.photo-add-icon {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.photo-add-text {
  font-size: 12px;
  color: #999;
  margin-top: 10rpx;
}

.photo-tip {
  display: block;
  font-size: 12px;
  color: #999;
  margin-top: 15rpx;
}

/* 付款方式和预估总价 */
.payment-price-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.payment-option {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.payment-text {
  font-size: 14px;
  color: #666;
}

.price-info {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.price-label {
  font-size: 14px;
  color: #666;
}

.price-value {
  font-size: 18px;
  font-weight: bold;
  color: #E60012;
}

.price-detail {
  font-size: 13px;
  color: #999;
  text-decoration: underline;
}

/* 下单按钮 */
.submit-section {
  padding: 24rpx;
  background-color: white;
  margin-bottom: 40rpx;
}

.agreement {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: white;
}

.agreement-text {
  font-size: 24rpx;
  color: #666;
}

.submit-btn {
  background: linear-gradient(135deg, #E60012 0%, #FF6B6B 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  height: 96rpx;
  border-radius: 48rpx;
  width: 100%;
  box-shadow: 0 8rpx 24rpx rgba(230, 0, 18, 0.3);
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.submit-btn::after {
  border: none;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: white;
  border-radius: 16rpx;
  width: 80%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  font-size: 16px;
  font-weight: bold;
  text-align: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-body {
  padding: 30rpx;
}

.modal-body .form-item {
  margin-bottom: 20rpx;
}

.modal-body .label {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 10rpx;
}

.modal-body .input {
  width: 100%;
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 15rpx;
  font-size: 14px;
  box-sizing: border-box;
}

.modal-body .textarea {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 14px;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.modal-footer button {
  flex: 1;
  border: none;
  border-radius: 0;
  font-size: 16px;
  height: 90rpx;
  line-height: 90rpx;
}

.modal-footer .cancel {
  background-color: #f5f5f5;
  color: #666;
}

.modal-footer .confirm {
  background-color: #E60012;
  color: white;
}

/* 通用样式 */
.section-label {
  font-size: 15px;
  color: #333;
  font-weight: bold;
}

.required-mark {
  font-size: 13px;
  color: #E60012;
  margin-left: 10rpx;
}

.arrow-right {
  font-size: 16px;
  color: #999;
}