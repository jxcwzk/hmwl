.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.section {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 14px;
  color: #E60012;
}

.info-form {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.form-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.form-item-full {
  flex-direction: column;
  align-items: flex-start;
}

.form-item-full .form-label {
  width: 100%;
  margin-bottom: 10rpx;
}

.form-item-full .form-input {
  width: 100%;
}

.form-label {
  width: 140rpx;
  font-size: 14px;
  color: #666;
}

.form-input {
  flex: 1;
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  padding: 0 15rpx;
  font-size: 14px;
}

.form-picker {
  flex: 1;
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  padding: 0 15rpx;
  display: flex;
  align-items: center;
  background-color: #fff;
}

.picker-text {
  font-size: 14px;
  color: #333;
}

.goods-photos {
  padding: 10rpx 0;
}

.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 5rpx;
  right: 5rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: white;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.photo-add {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed #ddd;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.photo-add-icon {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.photo-add-text {
  font-size: 12px;
  color: #999;
  margin-top: 10rpx;
}

.photo-tip {
  display: block;
  font-size: 12px;
  color: #999;
  margin-top: 15rpx;
}

.submit-btn {
  background-color: #E60012;
  color: white;
  font-size: 16px;
  font-weight: bold;
  height: 80rpx;
  border-radius: 10rpx;
  margin-top: 30rpx;
  margin-bottom: 30rpx;
}

.submit-btn::after {
  border: none;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: white;
  border-radius: 16rpx;
  width: 80%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  font-size: 16px;
  font-weight: bold;
  text-align: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-body {
  padding: 30rpx;
}

.modal-body .form-item {
  margin-bottom: 20rpx;
}

.modal-body .label {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 10rpx;
}

.modal-body .input {
  width: 100%;
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  padding: 0 15rpx;
  font-size: 14px;
  box-sizing: border-box;
}

.modal-body .textarea {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid #ddd;
  border-radius: 5rpx;
  padding: 15rpx;
  font-size: 14px;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.modal-footer button {
  flex: 1;
  border: none;
  border-radius: 0;
  font-size: 16px;
  height: 90rpx;
  line-height: 90rpx;
}

.modal-footer .cancel {
  background-color: #f5f5f5;
  color: #666;
}

.modal-footer .confirm {
  background-color: #E60012;
  color: white;
}
