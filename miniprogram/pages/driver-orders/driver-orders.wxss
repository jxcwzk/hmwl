.container {
  height: 100vh;
  background-color: #f5f5f5;
}

.tabs {
  display: flex;
  background-color: #fff;
  padding: 0 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #E60012;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background-color: #E60012;
  border-radius: 3rpx;
}

.order-list {
  height: calc(100vh - 120rpx);
  padding: 20rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
}

.order-status.pending {
  background-color: #fff7e6;
  color: #fa8c16;
}

.order-status.accepted {
  background-color: #e6f7ff;
  color: #1890ff;
}

.order-status.picked {
  background-color: #f6ffed;
  color: #52c41a;
}

.order-status.delivering {
  background-color: #fff0f6;
  color: #eb2f96;
}

.order-status.delivered {
  background-color: #f9f0ff;
  color: #722ed1;
}

.order-status.completed {
  background-color: #f5f5f5;
  color: #999;
}

.order-route {
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.route-point {
  display: flex;
  align-items: flex-start;
}

.point-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.point-dot.start {
  background-color: #E60012;
}

.point-dot.end {
  background-color: #52c41a;
}

.point-info {
  flex: 1;
}

.point-info .label {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.point-info .name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-right: 16rpx;
}

.point-info .phone {
  font-size: 26rpx;
  color: #666;
}

.point-info .address {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-top: 8rpx;
}

.route-line {
  width: 4rpx;
  height: 40rpx;
  background-color: #ddd;
  margin-left: 8rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.goods-info {
  font-size: 26rpx;
  color: #666;
}

.create-time {
  font-size: 24rpx;
  color: #999;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-accept {
  background-color: #E60012;
  color: #fff;
  border: none;
}

.btn-reject {
  background-color: #fff;
  color: #666;
  border: 1rpx solid #ddd;
}

.reject-reason {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
}
