.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.express-card {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.express-number {
  font-size: 14px;
  color: #666;
}

.express-status {
  font-size: 14px;
  font-weight: bold;
  color: #E60012;
}

.logistics-timeline {
  position: relative;
  padding-left: 30rpx;
}

.timeline-item {
  position: relative;
  margin-bottom: 20rpx;
}

.timeline-item.active .timeline-dot {
  background-color: #E60012;
  width: 16rpx;
  height: 16rpx;
}

.timeline-item.active .timeline-text {
  color: #333;
  font-weight: bold;
}

.timeline-dot {
  position: absolute;
  left: -30rpx;
  top: 5rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #ddd;
  z-index: 1;
}

.timeline-line {
  position: absolute;
  left: -24rpx;
  top: 17rpx;
  width: 2rpx;
  height: calc(100% + 20rpx);
  background-color: #ddd;
}

.timeline-content {
  padding-left: 15rpx;
}

.timeline-text {
  display: block;
  font-size: 14px;
  color: #666;
  margin-bottom: 5rpx;
}

.timeline-time {
  display: block;
  font-size: 12px;
  color: #999;
}

.map-section {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 15rpx;
  color: #333;
}

.map-placeholder {
  height: 300rpx;
  background-color: #f9f9f9;
  border-radius: 5rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.map-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.map-text {
  font-size: 14px;
  color: #999;
}

.action-buttons {
  display: flex;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  background-color: white;
  color: #E60012;
  font-size: 14px;
  height: 60rpx;
  border-radius: 5rpx;
  border: 1rpx solid #E60012;
}

.action-btn::after {
  border: none;
}