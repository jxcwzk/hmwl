.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.user-info-section {
  background: linear-gradient(135deg, #E60012 0%, #FF6B6B 100%);
  color: white;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(230, 0, 18, 0.3);
  position: relative;
  overflow: hidden;
}

.user-info-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-icon {
  font-size: 56rpx;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  display: block;
}

.user-tags {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.user-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.role-tag {
  background-color: rgba(255, 255, 255, 0.25);
  color: white;
}

.status-tag {
  background-color: #FFD700;
  color: #333;
}

.user-level {
  font-size: 26rpx;
  opacity: 0.9;
  display: block;
}

.login-btn {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: white;
  font-size: 30rpx;
  height: 88rpx;
  border-radius: 44rpx;
  margin: 20rpx;
  border: none;
  font-weight: 500;
}

.login-btn::after {
  border: none;
}

.service-section {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: #333;
}

.service-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  transition: background-color 0.2s;
}

.service-item:active {
  background-color: #f5f5f5;
}

.service-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.coupon-bg {
  background: linear-gradient(135deg, #FF9A9E 0%, #FECFEF 100%);
}

.points-bg {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.address-bg {
  background: linear-gradient(135deg, #96FBC4 0%, #F9F586 100%);
}

.service-bg {
  background: linear-gradient(135deg, #A9C9FF 0%, #FFBBEC 100%);
}

.service-icon {
  font-size: 36rpx;
}

.service-text {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.order-section {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-more {
  font-size: 14px;
  color: #999;
}

.order-status {
  display: flex;
  justify-content: space-around;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.order-icon {
  font-size: 30rpx;
  margin-bottom: 10rpx;
}

.order-text {
  font-size: 12px;
  color: #666;
}

.settings-section {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.setting-list {
  display: flex;
  flex-direction: column;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-text {
  font-size: 14px;
  color: #333;
}

.setting-arrow {
  font-size: 16px;
  color: #999;
}

.driver-section {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.driver-menu {
  display: flex;
  justify-content: space-around;
}

.driver-menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  position: relative;
}

.menu-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.order-bg {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
}

.stats-bg {
  background: linear-gradient(135deg, #4FACFE 0%, #00F2FE 100%);
}

.vehicle-bg {
  background: linear-gradient(135deg, #F093FB 0%, #F5576C 100%);
}

.settlement-bg {
  background: linear-gradient(135deg, #43E97B 0%, #38F9D7 100%);
}

.menu-icon {
  font-size: 36rpx;
}

.menu-text {
  font-size: 22rpx;
  color: #333;
}

.menu-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background-color: #E60012;
  color: white;
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 16rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 管理员工作台 */
.admin-section {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.admin-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.admin-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: 12rpx;
  transition: background-color 0.2s;
}

.admin-item:active {
  background-color: #f5f5f5;
}

.admin-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.driver-icon {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
}

.network-icon {
  background: linear-gradient(135deg, #43E97B 0%, #38F9D7 100%);
}

.stats-icon {
  background: linear-gradient(135deg, #4FACFE 0%, #00F2FE 100%);
}

.settlement-icon {
  background: linear-gradient(135deg, #F093FB 0%, #F5576C 100%);
}

.admin-text {
  font-size: 22rpx;
  color: #666;
}

.logout-btn {
  background-color: white;
  color: #E60012;
  font-size: 16px;
  height: 80rpx;
  border-radius: 10rpx;
  border: 1rpx solid #E60012;
  margin-bottom: 30rpx;
}

.logout-btn::after {
  border: none;
}